{
  "name": "smart-classroom-transcription",
  "version": "1.0.0",
  "description": "Real-time classroom transcription and summarization system",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon",
    "client:dev": "vite",
    "client:build": "vite build",
    "client:preview": "vite preview",
    "test": "npm run build && npm run test:smoke",
    "test:unit": "node --test --test-concurrency=1 tests/*.test.mjs",
    "test:e2e": "NODE_ENV=test node scripts/socket-e2e-test.mjs",
    "test:browser": "node scripts/browser-e2e-test.mjs",
    "test:browser:summary": "node scripts/browser-summary-verification.mjs",
    "test:smoke": "NODE_ENV=test node scripts/smoke-test.mjs",
    "build": "npm run client:build"
  },
  "keywords": [
    "transcription",
    "education",
    "real-time",
    "ai",
    "classroom"
  ],
  "author": "Smart Classroom Team",
  "license": "MIT",
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.4.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.76.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.3",
    "dotenv": "^16",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "form-data": "^4.0.0",
    "groq-sdk": "^0.34.0",
    "helmet": "^8.1.0",
    "isomorphic-dompurify": "^2.36.0",
    "lucide": "^0.471.0",
    "lucide-react": "^0.471.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.4.0",
    "uuid": "^9"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.22",
    "nodemon": "^3.1.10",
    "playwright-core": "^1.59.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.14",
    "vite": "^6.4.2"
  },
  "overrides": {
    "socket.io-parser": "^4.2.6"
  },
  "engines": {
    "node": ">=18.0.0 <21.0.0"
  }
}
