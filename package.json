{
  "name": "smart-classroom-transcription",
  "version": "1.0.0",
  "description": "Real-time classroom transcription and summarization system",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon",
    "client:dev": "vite",
    "client:build": "vite build",
    "client:preview": "vite preview",
    "db:migrate:async": "node scripts/apply-async-migration.mjs",
    "db:migrate:realtime": "node scripts/apply-native-realtime-migration.mjs",
    "db:preflight:archive": "node scripts/preflight-environment.mjs archive",
    "deploy:preflight": "node scripts/preflight-environment.mjs deployment",
    "db:migrate:production": "node scripts/migrate-production.mjs",
    "db:reset:production": "node scripts/reset-production.mjs",
    "db:rollback:production": "node scripts/rollback-production.mjs",
    "db:archive:production": "node scripts/archive-production.mjs",
    "db:archive:verify": "node scripts/verify-archive.mjs",
    "db:archive:restore": "node scripts/restore-archive.mjs",
    "db:verify:async": "node scripts/verify-async-migration.mjs",
    "db:verify:student-boundary": "node scripts/verify-production-student-boundary.mjs",
    "db:verify:es256": "node scripts/verify-supabase-es256.mjs",
    "test": "npm run build && npm run test:smoke",
    "test:unit": "node --test --test-concurrency=1 tests/*.test.mjs",
    "test:async": "node --test --test-concurrency=1 tests/async.api.test.mjs",
    "test:e2e": "npm run test:realtime:multi",
    "test:realtime:multi": "node scripts/realtime-multigroup-e2e.mjs",
    "test:browser": "VITE_SUPABASE_URL=https://example.supabase.co VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_test npm run client:build && node scripts/browser-e2e-test.mjs",
    "test:browser:security": "node scripts/browser-security-e2e.mjs",
    "test:audio:provider": "node scripts/verify-audio-provider.mjs",
    "test:openai:provider": "node scripts/verify-openai-provider.mjs",
    "test:local:core": "npm run test:unit && E2E_GROUP_COUNT=25 npm run test:realtime:multi && npm run test:browser && npm run test:browser:security && npm audit --audit-level=moderate && npm test",
    "test:local:providers": "npm run test:audio:provider && npm run test:openai:provider",
    "test:smoke": "NODE_ENV=test node scripts/smoke-test.mjs",
    "build": "npm run client:build"
  },
  "keywords": [
    "transcription",
    "education",
    "real-time",
    "ai",
    "classroom"
  ],
  "author": "Smart Classroom Team",
  "license": "MIT",
  "dependencies": {
    "@marsidev/react-turnstile": "1.5.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "2.110.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "3.4.12",
    "dotenv": "^16",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "lucide-react": "^0.471.0",
    "marked": "^18.0.0",
    "multer": "2.2.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.22",
    "nodemon": "^3.1.10",
    "playwright-core": "^1.59.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.14",
    "vite": "^6.4.2"
  },
  "engines": {
    "node": "24.x"
  }
}
