NODE_ENV=development
# Migration workstation only. Never add this variable to DigitalOcean.
# SUPABASE_DB_URL=postgresql://postgres:password@db.PROJECT_REF.supabase.co:5432/postgres
APP_PUBLIC_ORIGIN=http://localhost:10000
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=sb_publishable_
SUPABASE_SECRET_KEY=sb_secret_
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_
# Public Cloudflare Turnstile site key; required before enabling Supabase CAPTCHA.
VITE_TURNSTILE_SITE_KEY=
# Use independent random values of at least 32 characters.
AUTH_COOKIE_SECRET=
SESSION_JOIN_SECRET=
AUTH_COOKIE_TTL_SECONDS=2592000
CLASSROOM_SESSION_TTL_MINUTES=240
PENDING_SESSION_TTL_MINUTES=60
# Live audio stays on the Node bridge. Defaults are sized conservatively for a 512 MB service.
LIVE_AUDIO_MAX_BYTES=2097152
LIVE_AUDIO_MAX_CONCURRENCY=4
LIVE_AUDIO_CHUNK_MS=30000
SUMMARY_GRACE_MS=3000
SUMMARY_RECONCILE_EVERY=20
SUMMARY_MODEL=gpt-5-nano
PROVIDER_TIMEOUT_MS=60000
ALLOW_LEGACY_TEACHER_ALLOWLIST=false
OPENAI_API_KEY=
ELEVENLABS_KEY=
